<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_base">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:navigationIcon="@drawable/ic_arrow_left"
            app:titleTextColor="@color/ink"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="数据库配置"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/ink"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="配置远程数据库连接参数"
            android:textSize="13sp"
            android:textColor="@color/muted"
            android:layout_marginBottom="20dp" />

        <!-- 启用数据库开关 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="4dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/surface_card"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp"
                android:paddingVertical="14dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="启用数据库同步"
                        android:textSize="15sp"
                        android:textColor="@color/ink" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="开启后将数据同步到远程数据库"
                        android:textSize="12sp"
                        android:textColor="@color/muted"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <Switch
                    android:id="@+id/switch_enable_db"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:theme="@style/SwitchTheme" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/card_main"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="4dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/surface_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="连接参数"
                    android:textSize="13sp"
                    android:textColor="@color/muted"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="数据库地址"
                    android:textSize="12sp"
                    android:textColor="@color/muted"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/et_db_url"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:hint="https://your-database.com/api"
                    android:inputType="textUri"
                    android:textSize="14sp"
                    android:textColorHint="@color/muted_light"
                    android:textColor="@color/ink"
                    android:background="@drawable/edit_text_border"
                    android:paddingHorizontal="14dp"
                    android:enabled="false"
                    android:layout_marginBottom="14dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="数据库密钥"
                    android:textSize="12sp"
                    android:textColor="@color/muted"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/et_db_key"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:hint="输入您的数据库访问密钥"
                    android:inputType="text"
                    android:textSize="14sp"
                    android:textColorHint="@color/muted_light"
                    android:textColor="@color/ink"
                    android:background="@drawable/edit_text_border"
                    android:paddingHorizontal="14dp"
                    android:enabled="false"
                    android:layout_marginBottom="18dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_test_connection"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="测试数据库连接"
                    android:textSize="14sp"
                    android:textColor="@color/white"
                    app:backgroundTint="@color/primary"
                    app:cornerRadius="12dp"
                    android:stateListAnimator="@null"
                    android:enabled="false" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/card_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="4dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/surface_card"
            android:layout_marginTop="16dp"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/layout_steps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="连接状态"
                    android:textSize="13sp"
                    android:textColor="@color/muted"
                    android:layout_marginBottom="12dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="保存配置"
            android:textSize="14sp"
            android:textColor="@color/muted"
            app:backgroundTint="@color/surface_dim"
            app:cornerRadius="12dp"
            android:stateListAnimator="@null"
            android:layout_marginTop="16dp" />

    </LinearLayout>
</ScrollView>
