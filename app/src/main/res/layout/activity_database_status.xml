<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9FAFB"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:title="数据库状态"
            app:titleTextColor="#374151"
            app:titleTextAppearance="@style/TextAppearance.AppCompat.Title" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/white"
            android:layout_marginTop="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="连接状态"
                    android:textSize="14sp"
                    android:textColor="#9CA3AF"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:text="数据库地址"
                        android:textSize="15sp"
                        android:textColor="#374151" />

                    <TextView
                        android:id="@+id/tv_db_url"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="-"
                        android:textSize="15sp"
                        android:textColor="#374151"
                        android:ellipsize="middle"
                        android:maxLines="2" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:text="API Key"
                        android:textSize="15sp"
                        android:textColor="#374151" />

                    <TextView
                        android:id="@+id/tv_db_key"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="-"
                        android:textSize="15sp"
                        android:textColor="#374151"
                        android:maxLines="3"
                        android:lineSpacingMultiplier="1.2" />

                    <ImageView
                        android:id="@+id/iv_toggle_key"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:padding="6dp"
                        android:src="@drawable/ic_visibility_off"
                        android:contentDescription="显示/隐藏"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackgroundBorderless" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:text="网络状态"
                        android:textSize="15sp"
                        android:textColor="#374151" />

                    <TextView
                        android:id="@+id/tv_network_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="检测中..."
                        android:textSize="15sp"
                        android:textColor="#9CA3AF" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:text="数据库状态"
                        android:textSize="15sp"
                        android:textColor="#374151" />

                    <TextView
                        android:id="@+id/tv_database_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="检测中..."
                        android:textSize="15sp"
                        android:textColor="#9CA3AF" />
                </LinearLayout>

                <Button
                    android:id="@+id/btn_refresh_connection"
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:text="刷新"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#10B981"
                    android:minHeight="0dp"
                    android:paddingTop="0dp"
                    android:paddingBottom="0dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/white"
            android:layout_marginTop="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="数据统计"
                    android:textSize="14sp"
                    android:textColor="#9CA3AF"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:text="本地记录"
                        android:textSize="15sp"
                        android:textColor="#374151" />

                    <TextView
                        android:id="@+id/tv_local_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-"
                        android:textSize="15sp"
                        android:textColor="#374151" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:text="数据库记录"
                        android:textSize="15sp"
                        android:textColor="#374151" />

                    <TextView
                        android:id="@+id/tv_remote_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-"
                        android:textSize="15sp"
                        android:textColor="#374151" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btn_refresh_stats"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="刷新"
                        android:textSize="14sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#10B981"
                        android:minHeight="0dp"
                        android:paddingTop="0dp"
                        android:paddingBottom="0dp"
                        android:layout_marginEnd="8dp" />

                    <Button
                        android:id="@+id/btn_sync_now"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="立即同步"
                        android:textSize="14sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#9CA3AF"
                        android:minHeight="0dp"
                        android:paddingTop="0dp"
                        android:paddingBottom="0dp"
                        android:layout_marginStart="8dp" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/white"
            android:layout_marginTop="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="更新队列"
                        android:textSize="14sp"
                        android:textColor="#9CA3AF" />

                    <ImageView
                        android:id="@+id/iv_clear_queue"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:padding="2dp"
                        android:src="@drawable/ic_delete"
                        android:contentDescription="清除队列"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackgroundBorderless" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:text="待更新"
                        android:textSize="15sp"
                        android:textColor="#374151" />

                    <TextView
                        android:id="@+id/tv_pending_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 条数据"
                        android:textSize="15sp"
                        android:textColor="#374151" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:text="成功"
                        android:textSize="15sp"
                        android:textColor="#374151" />

                    <TextView
                        android:id="@+id/tv_success_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 条数据"
                        android:textSize="15sp"
                        android:textColor="#10B981" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:text="失败"
                        android:textSize="15sp"
                        android:textColor="#374151" />

                    <TextView
                        android:id="@+id/tv_failed_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 条数据"
                        android:textSize="15sp"
                        android:textColor="#EF4444" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <Button
                        android:id="@+id/btn_retry_failed"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="重试"
                        android:textSize="14sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#F59E0B"
                        android:minHeight="0dp"
                        android:paddingTop="0dp"
                        android:paddingBottom="0dp"
                        android:layout_marginEnd="8dp" />

                    <Button
                        android:id="@+id/btn_process_pending"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="处理队列"
                        android:textSize="14sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#10B981"
                        android:minHeight="0dp"
                        android:paddingTop="0dp"
                        android:paddingBottom="0dp"
                        android:layout_marginStart="8dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_sync_detail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="暂无更新条目"
                    android:textSize="13sp"
                    android:textColor="#9CA3AF"
                    android:background="#F9FAFB"
                    android:padding="10dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
