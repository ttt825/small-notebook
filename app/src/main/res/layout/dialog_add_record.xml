<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="20dp"
    app:cardElevation="8dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="添加记录"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1F2937"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="记录时间"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#6B7280"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tv_add_datetime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="2026-02-11 14:30"
            android:textSize="15sp"
            android:textColor="#1F2937"
            android:padding="14dp"
            android:background="@drawable/edit_text_border"
            android:layout_marginBottom="18dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="记录内容"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#6B7280"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/et_add_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="120dp"
            android:hint="请输入记录内容"
            android:textColorHint="#9CA3AF"
            android:background="@drawable/edit_text_border"
            android:padding="14dp"
            android:gravity="top|start"
            android:layout_marginBottom="10dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="快速预设"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#6B7280"
            android:layout_marginBottom="4dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_presets"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxHeight="100dp"
            android:layout_marginBottom="20dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F3F4F6"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <Button
                android:id="@+id/btn_cancel_add"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="取消"
                android:textSize="15sp"
                android:textColor="#6B7280"
                android:backgroundTint="#F3F4F6"
                app:cornerRadius="12dp"
                android:stateListAnimator="@null"
                android:layout_marginEnd="10dp" />

            <Button
                android:id="@+id/btn_confirm_add"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="添加"
                android:textSize="15sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#3B82F6"
                app:cornerRadius="12dp"
                android:stateListAnimator="@null" />
        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
