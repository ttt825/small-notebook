<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_base"
    android:fillViewport="true"
    android:paddingBottom="120dp"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- 数据分析卡片 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="4dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/surface_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="数据分析"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/ink"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_analysis_hint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="点击柱状图查看月份详情"
                    android:textSize="13sp"
                    android:textColor="@color/muted"
                    android:layout_marginBottom="16dp" />

                <LinearLayout
                    android:id="@+id/chart_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="年度记录趋势"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/ink_secondary"
                        android:layout_marginBottom="12dp" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/chart_recycler"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- 月份详情卡片 -->
        <androidx.cardview.widget.CardView
            android:id="@+id/month_detail_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="4dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/surface_card"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tv_month_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="2026年2月"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/ink" />

                    <TextView
                        android:id="@+id/tv_month_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="总记录数：0"
                        android:textSize="13sp"
                        android:textColor="@color/primary"
                        android:background="@color/primary_surface"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:layout_marginStart="8dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="内容统计"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/ink_secondary"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="12dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/content_stats_recycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- 空状态提示 -->
        <TextView
            android:id="@+id/tv_empty_analysis"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="暂无记录数据可分析"
            android:textSize="15sp"
            android:textColor="@color/muted_light"
            android:gravity="center"
            android:padding="40dp"
            android:visibility="gone" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
