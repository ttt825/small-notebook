<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_base"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="80dp">

        <!-- 月份切换 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingVertical="16dp"
            android:background="@color/surface_card"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/btn_prev_month"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:text="@string/prev_month"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:id="@+id/tv_current_month"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="2026年2月"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                android:textColor="@color/ink" />

            <TextView
                android:id="@+id/btn_next_month"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:text="@string/next_month"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless" />
        </LinearLayout>

        <!-- 星期标题 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/surface_card"
            android:paddingBottom="8dp"
            android:paddingHorizontal="4dp">

            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="日" android:textSize="13sp" android:textColor="@color/muted" android:gravity="center" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="一" android:textSize="13sp" android:textColor="@color/muted" android:gravity="center" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="二" android:textSize="13sp" android:textColor="@color/muted" android:gravity="center" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="三" android:textSize="13sp" android:textColor="@color/muted" android:gravity="center" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="四" android:textSize="13sp" android:textColor="@color/muted" android:gravity="center" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="五" android:textSize="13sp" android:textColor="@color/muted" android:gravity="center" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="六" android:textSize="13sp" android:textColor="@color/muted" android:gravity="center" />
        </LinearLayout>

        <!-- 日历网格 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/calendar_recycler"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:background="@color/surface_card"
            android:nestedScrollingEnabled="false" />

        <!-- 分隔 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:background="@color/surface_base" />

        <!-- 记录列表 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tv_selected_date"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="2026年2月11日"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/ink" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_add_record"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="添加记录"
                    android:textSize="14sp"
                    app:cornerRadius="20dp"
                    app:backgroundTint="@color/primary"
                    android:textColor="@color/white"
                    android:minWidth="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:paddingHorizontal="20dp" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="该日期记录"
                android:textSize="14sp"
                android:textColor="@color/muted"
                android:layout_marginBottom="12dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/records_recycler"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

            <TextView
                android:id="@+id/tv_empty_records"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="该日期暂无记录"
                android:textSize="15sp"
                android:textColor="@color/muted_light"
                android:gravity="center"
                android:padding="40dp"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
